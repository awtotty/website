---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const posts = await getCollection("blog");
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });

---

<Base title="Austin Totty">
  <p>AUSTIN TOTTY</p>

  <span class="spacer"></span>

  <p class="mb-0">CONTACT: <a href="mailto:hi@austin-totty.com">hi@austin-totty.com</a></p>
  <p>LOCATION: Los Angeles, USA</p>

  <span class="spacer"></span>

  <p>PROJECTS</p>

  <ul>
    {sortedProjects.map((project) => {
      const link = project.data.url ?? project.data.github;
      return (
        <li>
          [{project.data.title}]({link ? <a href={link} target="_blank">{link}</a> : "—"}) ... <a class="button" href={`/projects/${project.id}`}>read</a>
        </li>
      );
    })}
  </ul>

  <span class="spacer"></span>

  <p>THOUGHTS <a class="button" href="/blog/rss.xml" download>rss</a></p>

  <input
    id="thoughts-search"
    type="text"
    placeholder="search..."
    autocomplete="off"
  />

  <ul id="thoughts-list">
    {sortedPosts.map((post) => (
      <li data-search={`${post.data.title} ${post.data.description} ${formatDate(post.data.date)} ${(post.data.tags ?? []).join(" ")}`.toLowerCase()}>
        {post.data.title} ({formatDate(post.data.date)}) ... <a class="button" href={`/blog/${post.id}`}>read</a>
      </li>
    ))}
  </ul>

  <script>
    const input = document.getElementById("thoughts-search") as HTMLInputElement;
    const list = document.getElementById("thoughts-list");
    if (input && list) {
      const items = Array.from(list.querySelectorAll("li"));
      input.addEventListener("input", () => {
        const query = input.value.toLowerCase().trim();
        for (const item of items) {
          const haystack = (item as HTMLElement).dataset.search ?? "";
          if (!query || fuzzyMatch(query, haystack)) {
            item.style.display = "";
          } else {
            item.style.display = "none";
          }
        }
      });
    }

    function fuzzyMatch(query: string, text: string): boolean {
      let qi = 0;
      for (let ti = 0; ti < text.length && qi < query.length; ti++) {
        if (text[ti] === query[qi]) qi++;
      }
      return qi === query.length;
    }
  </script>
</Base>
